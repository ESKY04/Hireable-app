generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  OPERATOR
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum PackageType {
  COVER_LETTER
  RESUME
  FULL_SUITE
}

enum OrderStatus {
  SUBMITTED
  IN_QUEUE
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

model User {
  id                   String   @id @default(cuid())
  clerkId              String   @unique
  email                String   @unique
  name                 String?
  role                 UserRole @default(CLIENT)
  stripeId             String?
  stripeSubscriptionId String?
  plan                 Plan     @default(FREE)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  resumes      Resume[]
  coverLetters CoverLetter[]
  orders       Order[]
}

model Resume {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  content     Json
  tailoredFor String?
  score       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coverLetters CoverLetter[]

  @@index([userId])
}

model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId  String?
  resume    Resume?  @relation(fields: [resumeId], references: [id])
  jobTitle  String
  company   String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Order {
  id                String      @id @default(cuid())
  clientId          String
  client            User        @relation(fields: [clientId], references: [id])
  packageType       PackageType
  jobTitle          String
  company           String
  jobDescription    String      @db.Text
  location          String
  experienceLevel   String
  credentials       String      @db.Text
  currentResumeText String      @db.Text
  status            OrderStatus @default(SUBMITTED)
  priceCents        Int
  stripePaymentId   String?
  operatorNotes     String?     @db.Text
  createdAt         DateTime    @default(now())
  deliveredAt       DateTime?

  deliverable Deliverable?

  @@index([clientId])
  @@index([status])
}

model Deliverable {
  id                 String    @id @default(cuid())
  orderId            String    @unique
  order              Order     @relation(fields: [orderId], references: [id])
  resumeContent      String?   @db.Text
  coverLetterContent String?   @db.Text
  salaryReport       Json?
  approvedAt         DateTime?
  updatedAt          DateTime  @updatedAt
}
